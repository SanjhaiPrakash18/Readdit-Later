{
  "manifest_version": 3,
  "name": "Readdit Later",
  "version": "1.0.4",
  "description": "Save and manage your Reddit posts with ease",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "notifications",
    "identity",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://oauth.reddit.com/*",
    "https://api.reddit.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Readdit Later",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["detailed-view.html", "icons/*"],
      "matches": ["*://*.reddit.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://www.reddit.com https://oauth.reddit.com https://api.reddit.com http://localhost:3000"
  }
}